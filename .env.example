# Discord application bot token (Bot tab in Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Channel where the three leaderboard images are posted/edited
LEADERBOARD_CHANNEL_ID=

# Optional: comma-separated Discord user IDs allowed to run /refresh_leaderboard
ADMIN_USER_IDS=

WAKATIME_API_URL=https://wakatime.com/api/v1

# Week boundaries (Mon–Sun) in this IANA zone — Morocco uses Africa/Casablanca
TIMEZONE=Africa/Casablanca

UPDATE_INTERVAL_MINUTES=15
BUFFER_SLEEP_SECONDS=60
